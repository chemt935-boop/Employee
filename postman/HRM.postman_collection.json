          "mode": "raw",
          "raw": "{\n  \"employee_id\": {{employeeId}},\n  \"type\": \"bonus\",\n  \"value\": 100,\n  \"days\": 1,\n  \"from_date\": \"{{from}}\",\n  \"to_date\": \"{{to}}\"\n}"
        },
        "url": { "raw": "{{baseUrl}}/api/bonus-deductions", "host": ["{{baseUrl}}"], "path": ["api", "bonus-deductions"] }
